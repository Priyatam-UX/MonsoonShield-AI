# Google Gemini API Key (Required for live AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeather API Key (Optional - application will fall back to Hyderabad mock data if empty)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Firebase Web App client configuration details (Optional - fallback mock profile auth is default)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
